# Copy to .env (gitignored). CLI flags override these.
CANTABILE_DB=cantabile.db
CANTABILE_OUTPUT=./audio
CANTABILE_FORMAT=wav
CANTABILE_TOLERANCE=7.0
CANTABILE_SEARCH_COUNT=6
CANTABILE_SLEEP=1.0
CANTABILE_INSECURE=false
# CANTABILE_COOKIES=./cookies.txt
# CANTABILE_PROXY=socks5://127.0.0.1:1080

# Lyrics analyzer
# GENIUS_TOKEN=your_free_genius_api_token   # optional; enables Genius fallback
CANTABILE_LYRICS_CACHE=lyrics_cache.json

# Stem separation (Demucs). Point STEMS_DIR at a big drive, not the system SSD.
CANTABILE_STEMS_DIR=./stems
CANTABILE_DEMUCS_MODEL=htdemucs
CANTABILE_DEMUCS_SEGMENT=7.0
CANTABILE_DEMUCS_FORMAT=flac
CANTABILE_DEMUCS_DEVICE=cpu
